# Copy this file to .env and fill in your values. Never commit .env to git.

# Google Gemini API key — primary fetch + summarization (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-key-here

# Groq API key — summarization fallback when Gemini is rate-limited (https://console.groq.com/keys)
GROQ_API_KEY=your-groq-key-here

# Gmail sender — must have 2FA enabled and an App Password generated
GMAIL_SENDER=youremail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Report recipients (RECIPIENT_3 is optional)
RECIPIENT_1=first@example.com
RECIPIENT_2=second@example.com
# RECIPIENT_3=third@example.com
